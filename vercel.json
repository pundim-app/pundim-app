{
  "version": 2,
  "buildCommand": "npx expo export --platform web --output-dir public",
  "installCommand": "pnpm install",
  "framework": null,
  "public": true,
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
