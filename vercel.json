{
  "version": 2,
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev:metro",
  "installCommand": "pnpm install",
  "framework": null,
  "public": true,
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "server/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html"
    }
  ]
}
